# Database Configuration
DB_HOST=ecs-database-host
DB_USER=admin
DB_PASSWORD=secret
DB_NAME=poff
DB_CONNECTION_LIMIT=50

# Application Configuration
NODE_ENV=production
PORT=3000

# Firebase Configuration (Client-side config served via API)
VITE_FIREBASE_API_KEY=xxx
VITE_FIREBASE_AUTH_DOMAIN=xxx
VITE_FIREBASE_PROJECT_ID=xxx
VITE_FIREBASE_APP_ID=xxx
VITE_FIREBASE_MESSAGING_SENDER_ID=xxx

# Firebase Admin SDK (Server-side)
# Provide the service account JSON as a base64 encoded string or file path
FIREBASE_SERVICE_ACCOUNT=xxx

# Asset Configuration
SERVE_STATIC_ASSETS=false
VITE_ASSETS_BASE_URL=https://cdn.example.com
